{
  "id": "com.archtis.mattermost-policy-plugin",
  "name": "Mattermost Policy Plugin",
  "description": "Enforces external policy decisions via Direktiv for message and channel access control",
  "version": "1.0.0",
  "min_server_version": "9.0.0",
  "server": {
    "executables": {
      "linux-amd64": "server/dist/plugin-linux-amd64",
      "linux-arm64": "server/dist/plugin-linux-arm64",
      "darwin-amd64": "server/dist/plugin-darwin-amd64",
      "darwin-arm64": "server/dist/plugin-darwin-arm64",
      "windows-amd64": "server/dist/plugin-windows-amd64.exe"
    },
    "executable": ""
  },
  "settings_schema": {
    "header": "Configure the Mattermost Policy Plugin to integrate with Direktiv for external policy enforcement.",
    "footer": "For more information, see the plugin documentation.",
    "settings": [
      {
        "key": "DirektivURL",
        "display_name": "Direktiv Base URL",
        "type": "text",
        "help_text": "Base URL for your Direktiv instance (e.g., https://direktiv.example.com)",
        "placeholder": "https://direktiv.example.com",
        "default": ""
      },
      {
        "key": "DirektivNamespace",
        "display_name": "Direktiv Namespace",
        "type": "text",
        "help_text": "Namespace in Direktiv containing the policy workflows",
        "placeholder": "mattermost-policies",
        "default": "mattermost-policies"
      },
      {
        "key": "DirektivAPIKey",
        "display_name": "Direktiv API Key",
        "type": "text",
        "help_text": "API key for authenticating with Direktiv (optional)",
        "placeholder": "",
        "default": ""
      },
      {
        "key": "EnableMessagePolicy",
        "display_name": "Enable Message Policy Checks",
        "type": "bool",
        "help_text": "When enabled, all messages will be checked against the policy before posting",
        "default": true
      },
      {
        "key": "EnableChannelJoinPolicy",
        "display_name": "Enable Channel Join Policy Checks",
        "type": "bool",
        "help_text": "When enabled, users joining channels will be checked against the policy",
        "default": true
      },
      {
        "key": "EnableMessageEditPolicy",
        "display_name": "Enable Message Edit Policy Checks",
        "type": "bool",
        "help_text": "When enabled, message edits will be checked against the policy",
        "default": false
      },
      {
        "key": "EnableMessageDeletePolicy",
        "display_name": "Enable Message Delete Policy Checks",
        "type": "bool",
        "help_text": "When enabled, message deletions will be checked against the policy",
        "default": false
      },
      {
        "key": "EnableFileUploadPolicy",
        "display_name": "Enable File Upload Policy Checks",
        "type": "bool",
        "help_text": "When enabled, file uploads will be checked against the policy",
        "default": false
      },
      {
        "key": "EnableLoginPolicy",
        "display_name": "Enable Login Policy Checks",
        "type": "bool",
        "help_text": "When enabled, user logins will be checked against the policy",
        "default": false
      },
      {
        "key": "EnableChannelCreationPolicy",
        "display_name": "Enable Channel Creation Policy",
        "type": "bool",
        "help_text": "When enabled, new channels will be auto-classified and checked against policy",
        "default": false
      },
      {
        "key": "PolicyTimeout",
        "display_name": "Policy Request Timeout (seconds)",
        "type": "number",
        "help_text": "Maximum time to wait for policy decision before denying (fail-secure)",
        "placeholder": "5",
        "default": 5
      },
      {
        "key": "EnableDebugLogging",
        "display_name": "Enable Debug Logging",
        "type": "bool",
        "help_text": "Enable detailed logging for troubleshooting (may impact performance)",
        "default": false
      },
      {
        "key": "ExemptSystemAdmins",
        "display_name": "Exempt System Admins from Policy",
        "type": "bool",
        "help_text": "When enabled, system administrators bypass all policy checks",
        "default": false
      },
      {
        "key": "UserAttributeMapping",
        "display_name": "User Attribute Mapping (JSON)",
        "type": "longtext",
        "help_text": "JSON mapping of Mattermost user fields to policy attributes",
        "placeholder": "{\"clearance\": \"CustomAttribute1\", \"department\": \"CustomAttribute2\"}",
        "default": "{}"
      }
    ]
  }
}

